#!/bin/bash
service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/data" 2>/dev/null || true
}
service_preuninst() {
    # 通过 PID 文件杀进程，pkill 兜底用独特名
    if [ -f "${TRIM_PKGVAR}/data/server.pid" ]; then
        pid=$(cat "${TRIM_PKGVAR}/data/server.pid" 2>/dev/null | tr -d '[:space:]')
        case "$pid" in *[!0-9]*) ;; *) kill -TERM "$pid" 2>/dev/null || true; sleep 1; kill -KILL "$pid" 2>/dev/null || true ;; esac
    fi
    pkill -x fnos-terminal 2>/dev/null || true
}
