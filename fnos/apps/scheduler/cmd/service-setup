#!/bin/bash
# service-setup 与 mihomo 保持一致：只做无害操作，不杀/启进程
# 杀进程由 uninstall_callback 负责
# 启动由 fnOS 框架调 cmd/main start 负责
APP_VAR_DIR="${TRIM_PKGVAR}/data"
service_postinst() {
    mkdir -p "$APP_VAR_DIR" 2>/dev/null || true
}
service_preuninst() {
    # 什么都不做：进程在 upgrade_callback 后由 cmd/main start 重新拉起
    # 真正的清理在 uninstall_callback 里
    return 0
}
