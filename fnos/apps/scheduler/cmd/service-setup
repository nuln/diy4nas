#!/bin/bash
APP_VAR_DIR="${TRIM_PKGVAR}/data"
service_postinst() {
    mkdir -p "$APP_VAR_DIR" 2>/dev/null || true
    # 不在这里启动服务：fnOS 框架会自己调用 cmd/main start
    # 如果再启动一次会因端口冲突导致服务没起来
}
service_preuninst() {
    # 通过 PID 文件杀进程，pkill 兜底用独特名
    if [ -f "$APP_VAR_DIR/server.pid" ]; then
        pid=$(cat "$APP_VAR_DIR/server.pid" 2>/dev/null | tr -d '[:space:]')
        case "$pid" in *[!0-9]*) ;; *) kill -TERM "$pid" 2>/dev/null || true; sleep 1; kill -KILL "$pid" 2>/dev/null || true ;; esac
    fi
    pkill -x fnos-scheduler 2>/dev/null || true
}
