#!/bin/sh
# post-install: 准备数据目录 + 启动服务（兜底）
APP_VAR="${TRIM_PKGVAR:-/var/apps/scheduler/data}"
APP_DEST="${TRIM_APPDEST:-/var/apps/scheduler}"

mkdir -p "$APP_VAR" 2>/dev/null || true
# 确保 binary 可执行
[ -x "$APP_DEST/app/fnos-scheduler" ] && chmod 0755 "$APP_DEST/app/fnos-scheduler" 2>/dev/null || true
# 启动服务（fnOS 框架通常会调 cmd/main start，这里兜底）
"$APP_DEST/cmd/main" start 2>/dev/null || true
exit 0
