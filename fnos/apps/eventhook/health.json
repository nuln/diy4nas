{
    "schema": "2.0",
    "title": "事件钩子健康检查",
    "description": "检查事件钩子服务是否响应",
    "checks": [
      {
        "name": "service_listening",
        "type": "port",
        "host": "127.0.0.1",
        "port": 7683,
        "timeout": 20,
        "interval": 30,
        "fail_threshold": 3,
        "recovery_threshold": 2
      },
      {
        "name": "api_healthz",
        "type": "http",
        "method": "GET",
        "host": "127.0.0.1",
        "port": 7683,
        "path": "/api/healthz",
        "timeout": 20,
        "interval": 30,
        "expected_status": 200
      }
    ]
  }
