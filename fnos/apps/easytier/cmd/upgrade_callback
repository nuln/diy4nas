#!/bin/sh
# post-upgrade: restore and start
APP_DEST=${TRIM_APPDEST:-/var/apps/easytier}
APP_VAR=${TRIM_PKGVAR:-/var/apps/easytier/data}
if [ -f "$APP_VAR/config/settings.json.bak" ] && [ ! -f "$APP_VAR/config/settings.json" ]; then
    mv "$APP_VAR/config/settings.json.bak" "$APP_VAR/config/settings.json" 2>/dev/null || true
fi
"$APP_DEST/cmd/main" start 2>/dev/null || true
exit 0