#!/bin/sh
# pre-upgrade: backup and stop
APP_DEST=${TRIM_APPDEST:-/var/apps/tailscale}
APP_VAR=${TRIM_PKGVAR:-$APP_DEST/data}
if [ -f "$APP_VAR/settings.json" ]; then
    cp "$APP_VAR/settings.json" "$APP_VAR/settings.json.bak" 2>/dev/null || true
fi
"$APP_DEST/cmd/main" stop 2>/dev/null || true
exit 0
