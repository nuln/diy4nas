#!/bin/sh
NAME=app-center
APP_VAR=${TRIM_PKGVAR:-/var/apps/$NAME/data}
PID_FILE=$APP_VAR/$NAME.pid
LOG_FILE=$APP_VAR/$NAME.log
APP_DEST=${TRIM_APPDEST:-/var/apps/$NAME}
BIN="$APP_DEST/app/bin/app-center-server"
[ -x "$BIN" ] || BIN="$APP_DEST/bin/app-center-server"
start() { mkdir -p $APP_VAR; [ -x "$BIN" ] || { echo "app-center-server not found" > "${TRIM_TEMP_LOGFILE}"; exit 1; }; nohup "$BIN" $APP_VAR >> "$LOG_FILE" 2>&1 & echo $! > "$PID_FILE"; }
stop() { if [ -f "$PID_FILE" ]; then kill $(cat "$PID_FILE") 2>/dev/null; rm -f "$PID_FILE"; fi; exit 0; }
status() { [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null && exit 0 || exit 3; }
case "${1:-}" in start) start ;; stop) stop ;; restart) stop; sleep 1; start ;; status) status ;; *) echo "未知操作: $1" > "${TRIM_TEMP_LOGFILE}"; exit 1 ;; esac
